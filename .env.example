# ==========================================
# 股票分析与投资决策系统 - 环境配置
# ==========================================
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# 后端服务
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false

# 数据库（默认 SQLite，轻量够用）
# DATABASE_URL=sqlite+aiosqlite:///./data/cache/stock.db
# MySQL 可选：
# DATABASE_URL=mysql+aiomysql://user:password@mysql_host:3306/stock_db

# CORS
CORS_ORIGINS=["*"]

# 数据源
# 通达信数据目录（本地部署用）
# TDX_DATA_DIR=C:/zd_zxzq_gm
PRIMARY_DATA_SOURCE=eastmoney
FALLBACK_DATA_SOURCE=sina
TDX_ENABLED=false

# DeepSeek AI（选填，用于智能分析）
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_MODEL=deepseek-chat

# 日志
LOG_LEVEL=INFO

# ========== 初始管理员账号 ==========
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=your_secure_password_here
DEFAULT_ADMIN_NICKNAME=闲适老翁
FORCE_CHANGE_PASSWORD_ON_FIRST_LOGIN=true

# 演示账号（可选）
ENABLE_DEMO_USER=true
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
DEMO_NICKNAME=演示用户
