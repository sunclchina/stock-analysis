# =============================================================================
# 股票分析与投资决策系统 — 配置模板
#
# 使用方式:
#   1. 复制为 .env:  cp .env.example .env
#   2. 按需修改配置
#   3. 启动服务
#
# 注意:
#   🔴「必须」— 不配系统不安全，部署前务必设置
#   🟡「推荐」— 不配不影响核心功能，但建议配置
# =============================================================================

# ─── 后端服务 ──────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8081
BACKEND_RELOAD=false

# ─── 数据库 ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/cache/stock.db

# ─── CORS 跨域 ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8000"]

# ─── 数据源 ──────────────────────────────────────────────────────────
PRIMARY_DATA_SOURCE=eastmoney
FALLBACK_DATA_SOURCE=sina
TDX_DATA_DIR=./data/tdx
TDX_ENABLED=false

# ─── DeepSeek AI 大模型 ─────────────────────────────────────────────────
# 🟡 推荐配置:不配仅影响 AI 分析，核心行情/预警/选股不受影响
# 从 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# ─── JWT 认证密钥 ─────────────────────────────────────────────────────
# 🔴 必须配置！不配则 Token 签名不安全，有安全风险
# 可用以下命令生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# ─── 默认管理员账号 ──────────────────────────────────────────────────
# 首次启动自动创建;生产环境务必修改默认密码
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=your_secure_password_here
DEFAULT_ADMIN_NICKNAME=系统管理员
FORCE_CHANGE_PASSWORD_ON_FIRST_LOGIN=true

# ─── 演示账号(可选) ──────────────────────────────────────────────────
ENABLE_DEMO_USER=false
DEMO_USERNAME=demo
DEMO_PASSWORD=***
DEMO_NICKNAME=演示用户

# ─── HTTPS/SSL ─────────────────────────────────────────────────────────
# 启用后后端启动时加载 SSL 证书，通过 https:// 访问
# 证书文件需挂载到容器内，路径为容器内绝对路径
SSL_ENABLED=false
SSL_CERT_FILE=
SSL_KEY_FILE=

# ─── 日志 ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
