# 开发环境配置
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/cache/stock.db

# CORS
CORS_ORIGINS=["http://localhost:8080"]

# 数据源
PRIMARY_DATA_SOURCE=sina
FALLBACK_DATA_SOURCE=eastmoney
TDX_DATA_DIR=./data/tdx
TDX_ENABLED=false

# JWT
JWT_SECRET=dev-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# 默认管理员
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NICKNAME=系统管理员
FORCE_CHANGE_PASSWORD_ON_FIRST_LOGIN=false

# 演示账号
ENABLE_DEMO_USER=true
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
DEMO_NICKNAME=演示用户

# HTTPS/SSL 证书配置
# 开启后后端启动时会加载 SSL 证书，通过 https:// 访问
SSL_ENABLED=false
# SSL_CERT_FILE=C:\path\to\cert.pem
# SSL_KEY_FILE=C:\path\to\privkey.key

# 日志
LOG_LEVEL=INFO
