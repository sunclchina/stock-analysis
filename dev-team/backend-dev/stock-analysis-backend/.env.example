# =============================================================================
# 股票分析与投资决策系统 — 配置模板
#
# 使用方式：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 按需修改各项配置
#   3. 启动服务
#
# 注意：
#   🔴「必须」— 不配系统不安全，部署前务必设置
#   🟡「推荐」— 不配不影响核心功能，但建议配置
# =============================================================================

# ─── 后端服务 ──────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000             # 后端监听端口（原则⑦：前端端口固定 8080）
BACKEND_RELOAD=false          # 开发模式设为 true 开启热重载

# ─── 数据库 ────────────────────────────────────────────────────────────
# 默认 SQLite，生产建议迁移至 MySQL/PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/cache/stock.db

# ─── CORS 跨域 ─────────────────────────────────────────────────────────
# 允许访问的源，JSON 数组或逗号分隔
CORS_ORIGINS=["http://localhost:8080"]

# ─── 数据源 ──────────────────────────────────────────────────────────
# 主力数据源：sina / eastmoney / tdx_local
PRIMARY_DATA_SOURCE=sina
# 备用数据源：sina / eastmoney
FALLBACK_DATA_SOURCE=eastmoney
# 通达信本地数据目录（PRIMARY_DATA_SOURCE=tdx_local 时须正确配置）
TDX_DATA_DIR=./data/tdx

# ─── DeepSeek AI 大模型 ──────────────────────────────────────────────
# 🟡 推荐配置：不配仅影响 AI 分析，核心行情/预警/选股不受影响
# 从 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# ─── JWT 认证密钥 ────────────────────────────────────────────────────
# 🔴 必须配置！不配则 Token 签名不安全，有安全风险
# 可用以下命令生成： python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# ─── 默认管理员账号 ───────────────────────────────────────────────────
# 首次启动自动创建；生产环境务必修改默认密码
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=your_secure_password_here
DEFAULT_ADMIN_NICKNAME=系统管理员
FORCE_CHANGE_PASSWORD_ON_FIRST_LOGIN=true

# ─── 演示账号（可选） ─────────────────────────────────────────────────
ENABLE_DEMO_USER=false
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
DEMO_NICKNAME=演示用户

# ─── 日志 ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
