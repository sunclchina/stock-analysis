# =============================================================================
# 合并镜像 Dockerfile — 后端 + 前端 + 模板
# =============================================================================

FROM docker.m.daocloud.io/library/python:3.12-slim

LABEL maintainer="stock-analysis-system"
LABEL description="股票分析与投资决策系统"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# 后端代码
COPY dev-team/backend-dev/stock-analysis-backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY dev-team/backend-dev/stock-analysis-backend/backend ./backend

# 前端静态文件（main.py 从 backend/static/ 读取）
COPY dev-team/frontend-dev/stock-analysis-frontend/dist ./backend/static/.
RUN test -f /app/backend/static/index.html && echo "Frontend: OK" || echo "Frontend: MISSING"

# 模板文件（存储两份：data/templates 用于运行时，default_templates 用于恢复）
COPY dev-team/backend-dev/stock-analysis-backend/data/templates ./default_templates/.
RUN mkdir -p /app/data/templates && \
    cp -r /app/default_templates/* /app/data/templates/ && \
    echo "Templates: OK ($(ls /app/data/templates/*.md | wc -l) files)"

# .env
COPY dev-team/backend-dev/stock-analysis-backend/.env ./

# 数据目录
RUN for d in /app/data/cache /app/data/reports; do mkdir -p "$d" && chmod 777 "$d"; done && \
    echo '{"image":"stock-analysis:20260508","built":"2026-05-08"}' > /app/version.json

# 启动入口：如果 volume 把 templates 清空了，从 default_templates 恢复
RUN echo '#!/bin/bash' > /app/start.sh && \
    echo 'if [ ! -f /app/data/templates/.default_template ] || [ ! -f /app/data/templates/A股市场盘前提示模板.md ]; then' >> /app/start.sh && \
    echo '  echo "Restoring default templates..."' >> /app/start.sh && \
    echo '  cp -rn /app/default_templates/* /app/data/templates/ 2>/dev/null || true' >> /app/start.sh && \
    echo 'fi' >> /app/start.sh && \
    echo 'exec uvicorn backend.main:app --host 0.0.0.0 --port 8000 --log-level info' >> /app/start.sh && \
    chmod +x /app/start.sh

HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=15s \
    CMD curl -f http://localhost:8000/api/v1/health || exit 1

EXPOSE 8000

CMD ["/bin/bash", "/app/start.sh"]
