# =============================================================================
# 后端 Dockerfile — 股票分析与投资决策系统
# =============================================================================

FROM docker.m.daocloud.io/library/python:3.12-slim

LABEL maintainer="stock-analysis-system"
LABEL description="股票分析与投资决策系统 — 后端服务"

# 设置工作目录
WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 复制依赖文件并安装
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制项目代码
COPY . .

# 创建必要的数据目录
RUN mkdir -p /app/data/cache /app/data/reports /app/data/templates

# 暴露端口
EXPOSE 8000

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=15s \
    CMD curl -f http://localhost:8000/api/v1/health || exit 1

# 启动服务
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]
